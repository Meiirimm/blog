<!DOCTYPE html>
<html lang="en">
<head>
    <%-include('partials/head.ejs')%>
    <title>Document</title>
</head>
<body>
    <%-include('partials/header.ejs')%>
    <!-- <header>
        <div class="head-item head-logo">
            <a href="/">Decode Blog</a>
        </div>
        <div class="head-item head-search">
            <div class="head-search-input">
                <input type="text" placeholder="Поиск по блогам">
            </div>
            <div class="head-search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
                <button>Найти</button>
            </div>
        </div>
        <div class="head-item admin-head">
