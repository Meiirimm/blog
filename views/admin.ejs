    <div class="container">
        <div class="main">
            <div class="main-item prof-main">
                <div class="profile-main-item user-list">
                    <h1>Пользователи</h1>
                    <ul>
                        <% alluser.forEach(user => { %>
                            <%if(!user.isAdmin){%>
                                <li> 
                                    <%= user.full_name %> 
                                    <div class="menu">
                                        <div class="item"><a href="/editUsers/<%=user._id%>" class="edit">Заблокировать</a></div>
                                        <div class="item"><button onclick="deleteItem('<%=user._id%>')" class="delete">Удалить</button></div>
                                    </div>
                                </li>
                            <%}%>
                        <% }) %>
                    </ul>
                </div>
            </div>            
        </div>

        <div class="category profile-card">
            <div class="profile-img">
                <img src="/images/avatar.svg" alt="">
            </div>
            <div class="profile-body">
                    <h1><%=user.full_name%></h1>
                    <%
                        if(loginUser.id == user.id){
                    %>
                        <a href="">Редактировать</a>
                        <a href="/api/signout" class="logout-btn">Выход</a>
                    <%
                        }
                    %>
            </div>
        </div>
    </div>
    <script src="/functions/delete.js"></script>
    <script src="https://kit.fontawesome.com/0869a7851e.js" crossorigin="anonymous"></script>
    <script src="https://unpkg.com/axios/dist/axios.min.js"></script>
</body>
</html>